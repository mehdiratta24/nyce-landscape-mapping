# Public — safe to expose in client bundle
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGc...

# Server-only — used by:
#   - scripts/seed-supabase.ts (initial seed, bypasses RLS)
#   - admin server actions (approve/reject proposals, bulk upload)
# Never commit. Never expose to the client. Never set as NEXT_PUBLIC_*.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGc...

# Admin auth flag.
#   true  → /admin/* requires Supabase magic-link sign-in (production mode)
#   false → /admin/* is publicly accessible; no login required.
#           Admin actions still work because they use SUPABASE_SERVICE_ROLE_KEY.
# Default is false. Set to "true" once magic-link email delivery is sorted.
AUTH_ENABLED=false
